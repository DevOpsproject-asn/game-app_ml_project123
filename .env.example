"""Environment variables template"""
# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql://game_user:game_password@localhost:5432/game_analytics
MONGODB_URI=mongodb://admin:password@localhost:27017/game_analytics

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=sqlite:///mlruns/mlflow.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/game_ml.log

# Model Configuration
MODEL_PATH=models/
CHURN_MODEL_PATH=models/churn_model.pkl
FRAUD_MODEL_PATH=models/fraud_detector.pkl

# Feature Engineering
SCALING_METHOD=standardscaler
MISSING_STRATEGY=mean

# Monitoring
DRIFT_THRESHOLD=0.1
LOG_PREDICTIONS=True
